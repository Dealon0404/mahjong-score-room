OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o-mini
ALLOWED_ORIGIN=*

# Optional Python YOLO vision service. Do not commit third-party weights.
MAHJONG_YOLO_MODEL_PATH=C:\path\to\best.onnx
MAHJONG_YOLO_CLASSES_PATH=C:\path\to\classes.txt
MAHJONG_YOLO_IMAGE_SIZE=640
MAHJONG_YOLO_CONFIDENCE=0.30
MAHJONG_YOLO_IOU=0.45